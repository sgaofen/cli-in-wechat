{
  "name": "cli-in-wechat",
  "version": "0.1.0",
  "description": "Run Claude Code, Codex, Gemini CLI in WeChat via iLink Bot API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cli-in-wechat": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:debug": "tsx src/index.ts --debug",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
